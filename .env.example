# =============================================================================
# Local development
# =============================================================================
TA_ENV=development
TA_MODE=mock                  # mock | live (live needs OPENAI/ANTHROPIC keys)
TA_LOG_LEVEL=INFO
TA_DATA_DIR=./.tradingagents
TA_CACHE_TTL=86400

# =============================================================================
# Auth (closed beta)
# =============================================================================
TA_REQUIRE_INVITE=true
TA_JWT_SECRET=dev-secret-change-me-in-production
TA_JWT_TTL_HOURS=168
# Format: code:email,code:email,trial:* (* = any email)
TA_INVITE_CODES=trial:*

# Email allowlists - users on these lists get the corresponding upgrade
TA_REAL_LLM_USERS=
TA_REAL_DATA_USERS=

# =============================================================================
# CORS / API
# =============================================================================
TA_API_BASE_URL=http://localhost:8000
TA_ALLOWED_ORIGINS=http://localhost:3000

# =============================================================================
# Safety
# =============================================================================
TA_EMERGENCY_STOP=false
TA_RATE_LIMIT_PER_MIN=10
TA_ADMIN_TOKEN=

# =============================================================================
# LLM providers (leave blank for mock mode)
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

TA_MODEL_FAST=gpt-4o-mini
TA_MODEL_MID=claude-sonnet-4-6
TA_MODEL_DEEP=claude-opus-4-6

# =============================================================================
# Data providers
# =============================================================================
FINNHUB_API_KEY=
POLYGON_API_KEY=
ALPACA_API_KEY=
ALPACA_API_SECRET=

# =============================================================================
# Observability
# =============================================================================
SENTRY_DSN=
